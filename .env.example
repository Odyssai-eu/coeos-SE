# CoeOS SE — environment configuration (all optional; the key can also be pasted
# in the dashboard, where it's stored in coeos-config.json).

# OpenRouter key — the whole setup.
OPENROUTER_API_KEY=

# Require this bearer key on /v1/* and /admin/* (off when empty).
COEOS_API_KEY=

# Settings auto-update (poll the TMB Settings on GitHub, offer, never auto-apply).
#COEOS_SETTINGS_URL=https://raw.githubusercontent.com/Odyssai-eu/coeos-SE/main/coeos_se/settings/TMB-Settings-SE.json
#COEOS_UPDATE_INTERVAL=86400

# Server bind (defaults shown).
COEOS_HOST=0.0.0.0
COEOS_PORT=4600

# Config file location (default: ./coeos-config.json; docker: /data/coeos-config.json).
#COEOS_CONFIG=coeos-config.json
