# CoeOS SE — environment configuration (all optional; keys can also be pasted
# in the dashboard, where they're stored in coeos-config.json).

# Provider keys — one is enough; with both, resolution uses your priority
# setting and each covers the other's gaps.
OPENROUTER_API_KEY=
COMETAPI_KEY=

# Require this bearer key on /v1/* and /admin/* (off when empty).
COEOS_API_KEY=

# Server bind (defaults shown).
COEOS_HOST=0.0.0.0
COEOS_PORT=4600

# Config file location (default: ./coeos-config.json; docker: /data/coeos-config.json).
#COEOS_CONFIG=coeos-config.json
